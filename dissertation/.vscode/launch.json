{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Build and Preview Dissertation",
            "type": "shell",
            "request": "launch",
            "command": "echo 'Running build and preview tasks...'",
            "preLaunchTask": "latex-build",
            "postBuildTask": "latex-preview"
        }
    ],
    "compounds": [],
    "inputs": [],
    "tasks": [
        {
            "label": "latex-build",
            "type": "shell",
            "command": "cd dissertation && ./build.sh",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": []
        },
        {
            "label": "latex-preview",
            "type": "shell",
            "command": "xdg-open dissertation/out/dolgozat.pdf",
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "problemMatcher": []
        }
    ]
}