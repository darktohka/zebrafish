#!/bin/bash

. /lib/zebrafish/functions

if [ "$1" = "get" ]; then
    read target_hostname
    target_hostname=$(echo "$target_hostname" | sed -e 's/[^/]*\/\/\([^@]*@\)\?\([^:/]*\).*/\2/')

    if zf_has_present docker-registry; then
        eval "$(zebrafish-config --quiet list docker-registry --format shell)"
        count=${DOCKER_REGISTRY_COUNT:-0}

        for ((i = 0; i < count; i++)); do
            hvar="DOCKER_REGISTRY_${i}_HOSTNAME"
            uvar="DOCKER_REGISTRY_${i}_USERNAME"
            pvar="DOCKER_REGISTRY_${i}_PASSWORD"

            hostname="${!hvar}"
            username="${!uvar}"
            password="${!pvar}"

            if [[ "${target_hostname,,}" = "${hostname,,}" ]]; then
                echo "{\"Username\": \"$username\", \"Secret\": \"$password\"}"
                exit 0
            fi
        done
    fi

    echo "{\"Username\": \"\", \"Password\": \"\"}"
    exit 0
elif [ "$1" = "list" ]; then
    if zf_has_present docker-registry; then
        eval "$(zebrafish-config --quiet list docker-registry --format shell)"
        count=${DOCKER_REGISTRY_COUNT:-0}

        for ((i = 0; i < count; i++)); do
            hvar="DOCKER_REGISTRY_${i}_HOSTNAME"
            echo "${!hvar}"
        done
    fi

    exit 0
fi

exit 1
