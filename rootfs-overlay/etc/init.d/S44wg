#!/bin/bash
set -e

this=S44wg
. /lib/zebrafish/functions
assert_root $this

create_wg_config() {
  local interface="$1"
  local private_key="$2"
  local int_address="$3"
  local int_port="$4"
  local peer_info="$5"

  echo -e "[Interface]\nMTU = 1420\nPrivateKey = ${private_key}\nAddress = ${int_address}\nListenPort = ${int_port}\n\n$peer_info" > "/etc/wireguard/${interface}.conf"
}

create_wg_configs() {
  local wg_count
  wg_count=$(zebrafish-config --quiet list wg --format shell >/dev/null; \
    zebrafish-config --quiet list wg --format shell | grep -c '^WG_COUNT=' || true)
  wg_count=${wg_count:-0}
  if [[ "$wg_count" -eq 0 ]]; then
    # Try the other way: read the actual value.
    eval "$(zebrafish-config --quiet list wg --format shell)"
    wg_count=${WG_COUNT:-0}
  fi

  if [[ "$wg_count" -eq 0 ]]; then
    return 0
  fi

  for ((idx = 0; idx < wg_count; idx++)); do
    # Re-evaluate to populate the indexed variables.
    eval "$(zebrafish-config --quiet list wg --format shell)"

    local interface_var="WG_${idx}_NAME"
    local pk_var="WG_${idx}_PRIVATE_KEY"
    local addr_var="WG_${idx}_ADDRESS"
    local port_var="WG_${idx}_LISTEN_PORT"

    local interface="${!interface_var:-wg${idx}}"
    local private_key="${!pk_var}"
    local int_address="${!addr_var}"
    local int_port="${!port_var}"

    echo -n "Configuring WireGuard: interface $interface; internal address $int_address:$int_port; "

    # Build peer info
    local peers_var="WG_${idx}_PEERS_COUNT"
    local peer_count="${!peers_var:-0}"
    local peer_info=""

    for ((p = 0; p < peer_count; p++)); do
      local pname="WG_${idx}_PEERS_${p}"
      local p_pk="${pname}_PUBLIC_KEY"
      local p_endpoint="${pname}_ENDPOINT"
      local p_allowed="${pname}_ALLOWED_IPS_COUNT"
      local p_keepalive="${pname}_PERSISTENT_KEEPALIVE"

      local public_key="${!p_pk}"

      if [ -n "$peer_info" ]; then
        peer_info+="\n\n"
      fi

      peer_info+="[Peer]\nPublicKey = ${public_key}\n"

      # Allowed IPs
      local allowed_ips=""
      local allowed_count="${!p_allowed:-0}"
      for ((a = 0; a < allowed_count; a++)); do
        local av="${pname}_ALLOWED_IPS_${a}"
        if [ -z "$allowed_ips" ]; then
          allowed_ips="${!av}"
        else
          allowed_ips="$allowed_ips,${!av}"
        fi
      done
      peer_info+="AllowedIPs = ${allowed_ips}\nPersistentKeepalive = 25"
      echo -n "peer"

      if [ -n "${!p_endpoint:-}" ]; then
        peer_info+="\nEndpoint = ${!p_endpoint}"
        echo -n " at ${!p_endpoint}"
      fi

      echo -n " (allowed IPs: $allowed_ips); "
    done

    create_wg_config "$interface" "$private_key" "$int_address" "$int_port" "$peer_info"
    echo "OK"
  done
}

do_start () {
  create_wg_configs

  iptables -A FORWARD -p tcp --tcp-flags SYN,RST SYN -j TCPMSS  --clamp-mss-to-pmtu

  for interface in $(find /etc/wireguard -type f -iname 'wg*.conf'); do
    interface="$(basename "$interface" .conf)"
    echo "Starting WireGuard interface $interface: "
    wg-quick up "$interface" && echo "OK" || echo "FAIL"
  done
}

do_stop () {
  for interface in $(find /etc/wireguard -type f -iname 'wg*.conf'); do
    interface="$(basename "$interface" .conf)"
    echo "Stopping WireGuard interface $interface: "
    wg-quick down "$interface" && echo "OK" || echo "FAIL"
  done
}

case $1 in
  start)
    do_start
    ;;
  stop)
    do_stop
    ;;
  restart)
    do_stop
    sleep 1
    do_start
    ;;
  *)
    echo "Usage: $0 {start|stop|restart}"
    exit 1
esac
